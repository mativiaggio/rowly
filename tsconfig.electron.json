{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2020"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "rootDir": "./electron",
    "outDir": "./dist-electron",
    "sourceMap": true,
    "declaration": false,
    "noEmit": false
  },
  "include": ["electron/**/*.ts", "electron/*.ts"],
  "exclude": ["electron/electron-env.d.ts"]
}
